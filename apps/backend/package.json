{
  "name": "@apps/backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon index.js",
    "test": "vitest run",
    "dev:test": "pnpm test && pnpm dev",
    "e2e:vnpay:checkout": "node scripts/e2e-vnpay-checkout.js",
    "job:vnpay:reconcile": "node scripts/reconcile-pending-vnpay-payments.js",
    "storage:check": "node src/bootstrap/check-storage.js",
    "db:setup:account": "node src/modules/account/seeds/setup-account-indexes.js",
    "db:setup:catalog": "node src/modules/catalog/seeds/setup-catalog-indexes.js",
    "db:setup:cart": "node src/modules/cart/seeds/setup-cart-indexes.js",
    "db:setup:inventory": "node src/modules/inventory/seeds/setup-inventory-indexes.js",
    "db:setup:payment": "node src/modules/payment/seeds/setup-payment-indexes.js",
    "db:setup:ordering": "node src/modules/ordering/seeds/setup-ordering-indexes.js",
    "seed:account:admin": "pnpm run db:setup:account && node src/modules/account/seeds/seed-admin-account.js",
    "seed:catalog": "pnpm run db:setup:catalog && node src/modules/catalog/seeds/seed-catalog-base.js",
    "seed:catalog:storefront": "pnpm run db:setup:catalog && pnpm run db:setup:inventory && node src/modules/catalog/seeds/seed-storefront-catalog.js",
    "seed:e2e:vnpay": "node src/modules/catalog/seeds/seed-e2e-vnpay.js"
  },
  "devDependencies": {
    "nodemon": "^3.1.11",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "firebase-admin": "^13.7.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.1.0",
    "multer": "^2.1.1",
    "pino": "^10.3.1",
    "qs": "^6.15.0",
    "remove-accents": "^0.5.0",
    "slugify": "^1.6.6",
    "zod": "^4.3.6"
  }
}
