{
  "name": "@apps/frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "pact:test": "vitest run --config vitest.config.pact.js",
    "pact:publish": "pact-broker publish ./pacts --broker-base-url=\"$PACT_BROKER_URL\" --broker-token=\"$PACT_BROKER_TOKEN\" --consumer-app-version=\"${PACTICIPANT_VERSION:-dev-local}\" --branch=\"${GIT_BRANCH:-main}\"",
    "pact:can-i-deploy": "pact-broker can-i-deploy --broker-base-url=\"$PACT_BROKER_URL\" --broker-token=\"$PACT_BROKER_TOKEN\" --pacticipant retail-frontend --version \"${PACTICIPANT_VERSION:-dev-local}\" --to-environment \"${TARGET_ENV:-production}\""
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/noto-serif": "^5.2.9",
    "@packages/location-client": "workspace:*",
    "@tinymce/tinymce-vue": "^6.3.0",
    "axios": "^1.14.0",
    "chart.js": "^4.5.1",
    "material-symbols": "^0.44.3",
    "pinia": "^3.0.4",
    "tinymce": "^8.4.0",
    "vue": "^3.5.24",
    "vue-chartjs": "^5.3.2",
    "vue-router": "^4.6.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@pact-foundation/pact": "^16.3.0",
    "@pact-foundation/pact-node": "^10.18.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/test-utils": "^2.4.6",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "vite": "^7.2.4",
    "vitest": "^4.0.18"
  }
}
