      "providerStates": [
        {
          "name": "catalog discovery options exist for smartphone category"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/catalog/discovery-options",
        "query": {
          "categoryCode": [
            "SMARTPHONE"
          ],
          "productType": [
            "smartphone"
          ]
        }
      },
      "response": {
        "body": {
          "data": {
            "brands": [
              {
                "label": "Apple",
                "value": "APPLE"
              }
            ],
            "colors": [
              {
                "label": "Blue",
                "value": "Blue"
              }
            ],
            "priceBounds": {
              "max": 30000000,
