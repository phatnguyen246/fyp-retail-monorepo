            "$.data.slug": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data.title": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data.variants": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.data.variants[*].id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data.variants[*].isInStock": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data.variants[*].sku": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.meta.canonicalSlug": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request for storefront product listing",
      "providerStates": [
        {
          "name": "catalog product list exists for smartphone storefront"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/catalog/products",
        "query": {
          "categoryCode": [
            "SMARTPHONE"
          ],
          "limit": [
            "12"
          ],
          "page": [
            "1"
          ],
          "productType": [
            "smartphone"
          ],
          "sortMode": [
            "newest"
          ]
        }
      },
      "response": {
        "body": {
          "data": [
            {
              "hasInStockVariants": true,
              "id": "65f100000000000000000010",
              "minSalePrice": 24990000,
              "slug": "dien-thoai-iphone-16",
              "title": "iPhone 16"
            }
          ],
          "meta": {
            "limit": 12,
            "page": 1,
            "total": 1,
            "totalPages": 1
          }
        },
        "headers": {
          "Content-Type": "application/json; charset=utf-8"
        },
        "matchingRules": {
          "body": {
            "$.data": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.data[*].hasInStockVariants": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data[*].id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data[*].minSalePrice": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$.data[*].slug": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data[*].title": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.meta.limit": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$.meta.page": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$.meta.total": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$.meta.totalPages": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            }
          }
        },
        "status": 200
      }
    }
