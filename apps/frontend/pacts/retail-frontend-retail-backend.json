                }
              ]
            },
            "$.data.ram[*].label": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data.ram[*].value": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data.rom": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
