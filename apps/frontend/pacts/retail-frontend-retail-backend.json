    {
      "description": "a request for storefront product detail",
      "providerStates": [
        {
          "name": "catalog product detail exists for iphone 16"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/catalog/products/65f100000000000000000010/dien-thoai-iphone-16"
      },
      "response": {
        "body": {
          "data": {
            "id": "65f100000000000000000010",
            "minSalePrice": 24990000,
            "slug": "dien-thoai-iphone-16",
            "title": "iPhone 16",
            "variants": [
              {
                "id": "65f100000000000000000020",
                "isInStock": true,
                "sku": "IP16-BLU-256"
              }
            ]
          },
          "meta": {
            "canonicalSlug": "dien-thoai-iphone-16"
          }
        },
        "headers": {
          "Content-Type": "application/json; charset=utf-8"
        },
        "matchingRules": {
          "body": {
            "$.data.id": {
              "combine": "AND",
              "matchers": [
